# Commerce mode: "waitlist" (browse only, purchase disabled — default) or "live".
NEXT_PUBLIC_COMMERCE_MODE=waitlist

# Cart backend: "mock" (local, no Shopify needed — default) or "shopify".
NEXT_PUBLIC_COMMERCE_PROVIDER=mock

# Required once NEXT_PUBLIC_COMMERCE_PROVIDER=shopify (server-side only,
# never exposed to the browser):
# SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
# SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# Unlocks /preview (consultant mode switcher). Server-side only, never
# NEXT_PUBLIC. Unset = preview unlock disabled.
# PREVIEW_PASSWORD=

# Review collector storage (heldi-dev Supabase project). Server-side only,
# never NEXT_PUBLIC. The service_role key bypasses RLS, so keep it secret.
# Schema: supabase/migrations/0001_create_reviews.sql
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=

# Analytics (PostHog EU cloud). Public write-only project key, safe in the
# client bundle; without it the site runs with analytics off (dataLayer only).
# NEXT_PUBLIC_POSTHOG_KEY=phc_...

# Shopify orders/create webhook -> PostHog purchase events (server-side only;
# signing secret from Shopify admin -> Settings -> Notifications -> Webhooks).
# Setup: docs/launch-runbook.md Phase 6.5.
# SHOPIFY_WEBHOOK_SECRET=
